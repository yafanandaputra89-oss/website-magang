generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  mahasiswa
  dosen
  admin
  perusahaan
}

// ── Fix 1: pindahkan enum ke atas sebelum dipakai ─────────────────────────────
enum StatusLamaran {
  PENDING_BERKAS
  BERKAS_DITERIMA
  BERKAS_DITOLAK
  INTERVIEW_DIJADWALKAN
  LOLOS_INTERVIEW
  TIDAK_LOLOS_INTERVIEW
  DITERIMA_MAGANG
  KONFIRMASI_DITERIMA
  DITOLAK
}

// ── BARU — status periode magang berjalan (terpisah dari StatusLamaran) ──────
enum StatusMagang {
  Aktif
  Selesai
  Cuti
  Dropout
}

model User {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(100)
  username  String?   @unique @db.VarChar(100)
  email     String    @unique @db.VarChar(100)
  password  String    @db.VarChar(255)
  role      Role
  status    String    @default("Aktif")
  lastLogin DateTime?
  createdAt DateTime  @default(now()) @map("created_at")

  mahasiswa  Mahasiswa?
  perusahaan Perusahaan?
  dosen      Dosen?
  auditLogs  AuditLog[]
  // ── Fix 2: notifikasi berelasi ke User, bukan Mahasiswa ──────────────────────
  notifikasi Notifikasi[]

  @@map("users")
}

model Mahasiswa {
  id     Int @id @default(autoincrement())
  userId Int @unique

  nim      String? @unique
  prodi    String?
  angkatan String?
  semester Int?
  ipk      Float?
  totalSks Int?

  name       String?
  about      String? @db.Text
  alamat     String?
  telepon    String?
  fotoProfil String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Fix 3: hapus jadwalInterview dari sini, letaknya di Lamaran ──────────────
  skills         Skill[]
  pendidikans    Pendidikan[]
  pengalamans    Pengalaman[]
  sosialMedia    SosialMedia?
  lamarans       Lamaran[]
  konversiSks    KonversiSks[]
  laporanMagang  LaporanMagang[]
  pengajuanDosen PengajuanDosenPembimbing[]

  @@map("mahasiswa")
}

model Skill {
  id          Int    @id @default(autoincrement())
  mahasiswaId Int
  name        String

  mahasiswa Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("skills")
}

model Pendidikan {
  id          Int @id @default(autoincrement())
  mahasiswaId Int

  school      String
  degree      String
  startYear   String
  endYear     String
  description String? @db.Text

  mahasiswa Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("pendidikan")
}

model Pengalaman {
  id          Int @id @default(autoincrement())
  mahasiswaId Int

  role        String
  company     String
  type        String?
  startDate   String
  endDate     String?
  location    String?
  description String? @db.Text

  mahasiswa Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("pengalaman")
}

model SosialMedia {
  id          Int @id @default(autoincrement())
  mahasiswaId Int @unique

  instagram String?
  twitter   String?
  github    String?
  website   String?

  mahasiswa Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)

  @@map("sosial_media")
}

model Perusahaan {
  id     Int @id @default(autoincrement())
  userId Int @unique

  nama             String?
  deskripsiSingkat String? @db.VarChar(255)
  logo             String? @db.VarChar(10)
  bidang           String?
  alamat           String?
  telepon          String?
  ukuran           String?
  tahunBerdiri     String?
  website          String?
  linkedin         String?
  instagram        String?
  deskripsi        String? @db.Text
  kultur           String? @db.Text
  nilaiKultur      String? @db.Text // JSON string

  namaCP    String?
  jabatanCP String?

  statusVerifikasi  String    @default("MENUNGGU")
  catatanVerifikasi String?   @db.Text
  tanggalVerifikasi DateTime?

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lowongans Lowongan[]
  galeri    GaleriPerusahaan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("perusahaan")
}

model GaleriPerusahaan {
  id           Int    @id @default(autoincrement())
  perusahaanId Int
  image        String @db.Text
  label        String @db.VarChar(100)

  perusahaan Perusahaan @relation(fields: [perusahaanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("galeri_perusahaan")
}

model Lowongan {
  id           Int       @id @default(autoincrement())
  perusahaanId Int
  slug         String    @unique
  posisi       String
  departemen   String?
  kuota        Int
  deadline     DateTime?
  status       String    @default("Aktif")

  tipe       String?
  durasi     String?
  target     Int?
  tags       String? @db.Text
  gaji       String?
  lokasi     String?
  experience String?
  deskripsi  String? @db.Text

  responsibilities String? @db.Text
  requirements     String? @db.Text
  whoYouAre        String? @db.Text
  niceToHave       String? @db.Text

  perusahaan Perusahaan @relation(fields: [perusahaanId], references: [id], onDelete: Cascade)
  pelamars   Pelamar[]
  lamarans   Lamaran[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lowongan")
}

model Pelamar {
  id         Int    @id @default(autoincrement())
  lowonganId Int
  nama       String
  posisi     String
  status     String @default("Menunggu Review")

  lowongan Lowongan @relation(fields: [lowonganId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("pelamar")
}

model SkillKebutuhan {
  id         Int    @id @default(autoincrement())
  label      String
  percentage Int

  @@map("skill_kebutuhan")
}

model Dosen {
  id     Int @id @default(autoincrement())
  userId Int @unique

  name       String?
  nip        String? @unique
  nidn       String? @unique
  position   String?
  rank       String?
  department String?
  faculty    String?
  email      String?
  phone      String?
  office     String?
  bio        String? @db.Text
  avatar     String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  educations DosenEducation[]
  courses    DosenCourse[]
  expertises DosenExpertise[]
  certs      DosenCertification[]

  bimbinganLamarans          Lamaran[]
  laporanMagang              LaporanMagang[]
  pengajuanSebagaiUsulan     PengajuanDosenPembimbing[] @relation("DosenUsulan")
  pengajuanSebagaiDitetapkan PengajuanDosenPembimbing[] @relation("DosenDitetapkan")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dosen")
}

model DosenEducation {
  id      Int    @id @default(autoincrement())
  dosenId Int
  degree  String
  school  String
  year    String

  dosen Dosen @relation(fields: [dosenId], references: [id], onDelete: Cascade)

  @@map("dosen_education")
}

model DosenCourse {
  id       Int    @id @default(autoincrement())
  dosenId  Int
  course   String
  level    String
  semester String

  dosen Dosen @relation(fields: [dosenId], references: [id], onDelete: Cascade)

  @@map("dosen_course")
}

model DosenExpertise {
  id      Int    @id @default(autoincrement())
  dosenId Int
  tag     String

  dosen Dosen @relation(fields: [dosenId], references: [id], onDelete: Cascade)

  @@map("dosen_expertise")
}

model DosenCertification {
  id      Int    @id @default(autoincrement())
  dosenId Int
  title   String
  issuer  String
  year    String

  dosen Dosen @relation(fields: [dosenId], references: [id], onDelete: Cascade)

  @@map("dosen_certification")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  userName    String?
  role        String?
  action      String
  description String   @db.Text
  module      String
  ipAddress   String?
  status      String   @default("BERHASIL")
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Lamaran {
  id Int @id @default(autoincrement())

  mahasiswaId Int
  lowonganId  Int

  dosenPembimbingId Int?

  name       String
  email      String
  phone      String
  university String
  major      String?
  semester   String?
  portfolio  String?
  skills     String? @db.Text
  motivation String  @db.Text

  cvFile      String
  coverLetter String?
  transcript  String?

  startDate DateTime
  duration  String

  status StatusLamaran @default(PENDING_BERKAS)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jadwalInterview JadwalInterview?
  notifikasi      Notifikasi[]
  konversiSks     KonversiSks[]
  laporanMagang   LaporanMagang[]
  pengajuanDosen  PengajuanDosenPembimbing?
  // ── BARU — 1:1 dengan periode magang berjalan, dibuat otomatis saat
  //    status berubah menjadi KONFIRMASI_DITERIMA ────────────────────────────
  magang          Magang?
  mahasiswa       Mahasiswa                 @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  lowongan        Lowongan                  @relation(fields: [lowonganId], references: [id], onDelete: Cascade)

  dosenPembimbing Dosen? @relation(fields: [dosenPembimbingId], references: [id], onDelete: SetNull)

  @@map("lamaran")
}

model JadwalInterview {
  id          Int      @id @default(autoincrement())
  lamaranId   Int      @unique
  tanggal     DateTime
  jam         String
  lokasi      String
  linkMeeting String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lamaran Lamaran @relation(fields: [lamaranId], references: [id], onDelete: Cascade)

  @@map("jadwal_interview")
}

// ── BARU — periode magang berjalan milik satu Lamaran yang sudah
//    dikonfirmasi. Menyimpan status Aktif/Selesai/Cuti/Dropout, tanggal
//    mulai/selesai, dan siapa pembimbing di sisi perusahaan.
model Magang {
  id        Int @id @default(autoincrement())
  lamaranId Int @unique

  tanggalMulai   DateTime
  tanggalSelesai DateTime?

  pembimbingPerusahaan String?
  status               StatusMagang @default(Aktif)
  catatan              String?      @db.Text // alasan Cuti/Dropout, dll

  lamaran Lamaran @relation(fields: [lamaranId], references: [id], onDelete: Cascade)

  penilaians PenilaianPerusahaan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("magang")
}

// ── BARU — penilaian dari perusahaan terhadap peserta magang, terpisah dari
//    LaporanMagang (yang field dosenId-nya wajib dan ditujukan utk dosen).
model PenilaianPerusahaan {
  id       Int @id @default(autoincrement())
  magangId Int

  periode  String // cth: "Bulan ke-1", "Final"
  nilai    Int // 0–100
  feedback String @db.Text

  dinilaiOlehUserId Int? // opsional: user (perusahaan) yang mengisi

  magang Magang @relation(fields: [magangId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("penilaian_perusahaan")
}

model Notifikasi {
  id        Int      @id @default(autoincrement())
  // ── Fix 6: userId merujuk ke User (bukan Mahasiswa) ──────────────────────────
  userId    Int
  lamaranId Int?
  judul     String
  pesan     String
  dibaca    Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lamaran Lamaran? @relation(fields: [lamaranId], references: [id], onDelete: SetNull)

  @@map("notifikasi")
}

model KonversiSks {
  id Int @id @default(autoincrement())

  mahasiswaId Int
  lamaranId   Int

  kode     String
  nama     String
  sks      Int
  kategori String
  prodi    String?
  cpmk     String? @db.Text
  objektif String? @db.Text

  status     String @default("menunggu")
  keterangan String @default("Sedang menunggu review koordinator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mahasiswa Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  lamaran   Lamaran   @relation(fields: [lamaranId], references: [id], onDelete: Cascade)

  @@map("konversi_sks")
}

model LaporanMagang {
  id          Int @id @default(autoincrement())
  lamaranId   Int
  mahasiswaId Int
  dosenId     Int

  tanggal  DateTime
  judul    String
  catatan  String?  @db.Text
  fileUrl  String   @db.Text
  status   String   @default("MENUNGGU_REVIEW")
  nilai    Int?
  feedback String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lamaran   Lamaran   @relation(fields: [lamaranId], references: [id], onDelete: Cascade)
  mahasiswa Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  dosen     Dosen     @relation(fields: [dosenId], references: [id], onDelete: Cascade)

  @@map("laporan_magang")
}

/**
 * ═══════════════════════════════════════════════════════════════════════════
 * PENGAJUAN DOSEN PEMBIMBING
 * ───────────────────────────────────────────────────────────────────────────
 * Skenario A — mahasiswa memilih dosen sendiri (dosenUsulanId diisi):
 * MENUNGGU_PERSETUJUAN_DOSEN (sumberPenetapan=MAHASISWA)
 * → dosen setuju   → MENUNGGU_PENGESAHAN_ADMIN → admin sahkan → BIMBINGAN_AKTIF
 * → dosen tolak    → DITOLAK_DOSEN
 * Skenario B — mahasiswa tidak memilih dosen (dosenUsulanId kosong):
 * MENUNGGU_VERIFIKASI_PRODI (sumberPenetapan=null)
 * → admin tunjuk dosen → MENUNGGU_PERSETUJUAN_DOSEN (sumberPenetapan=ADMIN)
 * → dosen setuju → BIMBINGAN_AKTIF (langsung)
 * → dosen tolak  → DITOLAK_DOSEN
 * ═══════════════════════════════════════════════════════════════════════════
 */

enum StatusPengajuanDosen {
  MENUNGGU_VERIFIKASI_PRODI // mahasiswa belum punya dosen, menunggu admin menunjuk
  MENUNGGU_PERSETUJUAN_DOSEN // menunggu dosen setuju/tolak (usulan mahasiswa ATAU tunjukan admin)
  MENUNGGU_PENGESAHAN_ADMIN // BARU — dosen sudah setuju atas usulan mahasiswa, tinggal disahkan admin
  DITOLAK_DOSEN
  BIMBINGAN_AKTIF
  SELESAI
}

// BARU — menandai siapa yang menetapkan dosenDitetapkanId, agar controller tahu
// setelah dosen setuju harus ke MENUNGGU_PENGESAHAN_ADMIN atau langsung BIMBINGAN_AKTIF
enum SumberPenetapanDosen {
  MAHASISWA
  ADMIN
}

model PengajuanDosenPembimbing {
  id          Int @id @default(autoincrement())
  lamaranId   Int @unique
  mahasiswaId Int

  dosenUsulanId     Int?
  dosenDitetapkanId Int?
  sumberPenetapan   SumberPenetapanDosen? // BARU

  alasanMemilih   String  @db.Text
  catatanTambahan String? @db.Text

  status          StatusPengajuanDosen @default(MENUNGGU_VERIFIKASI_PRODI)
  alasanPenolakan String?              @db.Text
  catatanProdi    String?              @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lamaran         Lamaran   @relation(fields: [lamaranId], references: [id], onDelete: Cascade)
  mahasiswa       Mahasiswa @relation(fields: [mahasiswaId], references: [id], onDelete: Cascade)
  dosenUsulan     Dosen?    @relation("DosenUsulan", fields: [dosenUsulanId], references: [id], onDelete: SetNull)
  dosenDitetapkan Dosen?    @relation("DosenDitetapkan", fields: [dosenDitetapkanId], references: [id], onDelete: SetNull)

  riwayatStatus RiwayatStatusPengajuan[]

  @@map("pengajuan_dosen_pembimbing")
}

model RiwayatStatusPengajuan {
  id          Int @id @default(autoincrement())
  pengajuanId Int

  status        StatusPengajuanDosen
  keterangan    String?              @db.Text
  changedById   Int?
  changedByRole String?

  createdAt DateTime @default(now())

  pengajuan PengajuanDosenPembimbing @relation(fields: [pengajuanId], references: [id], onDelete: Cascade)

  @@map("riwayat_status_pengajuan")
}
